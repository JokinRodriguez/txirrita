---
const broadcasts = [
    { year: "2025", duration: "4:08:42", title: "2025 Retransmisioa", subtitle: "LASTERKETA OSOA", img: "https://img.youtube.com/vi/MvpFwpWNW7U/maxresdefault.jpg", active: true, link: "https://www.youtube.com/watch?v=MvpFwpWNW7U" },
    { year: "2024", duration: "4:12:45", title: "2024 Retransmisioa", subtitle: "LASTERKETA OSOA", img: "https://img.youtube.com/vi/vuuRS4biLHo/maxresdefault.jpg", active: false, link: "https://www.youtube.com/watch?v=vuuRS4biLHo" },
    { year: "2023", duration: "3:58:10", title: "2023 Retransmisioa", subtitle: "LASTERKETA OSOA", img: "https://img.youtube.com/vi/YTcyP8A0hfE/maxresdefault.jpg", active: false, link: "https://www.youtube.com/watch?v=YTcyP8A0hfE" }
];

const highlights = [
    "/highlights/53902038638_bc33e85350_c.jpg",
    "/highlights/54613520916_2776ce9d16_c.jpg",
    "/highlights/54613710349_55ce56087d_c.jpg",
    "/highlights/54613747669_8139c26c06_c.jpg",
    "/highlights/54613758243_e0260c8972_c.jpg",
    "/highlights/54613759488_a699f2b745_c.jpg",
    "/highlights/54613762458_3b104387d0_c.jpg",
    "/highlights/54613851710_5b73090506_c.jpg",
    "/highlights/54613852315_8179271779_c.jpg"
];

const albums = [
    { title: "2025. Edizioa", photos: "+2000 ARGAZKI", year: "2025", img: "https://live.staticflickr.com/65535/54613742539_880e79281a_b.jpg", link: "https://www.flickr.com/photos/198890299@N03/albums/72177720327133094" },
    { title: "2024. Edizioa", photos: "+300 ARGAZKI", year: "2024", img: "https://live.staticflickr.com/65535/53902223015_d833be0ba5_4k.jpg", link: "https://www.flickr.com/photos/198890299@N03/albums/72177720319326848" },
    { title: "2023. Edizioa", photos: "+450 ARGAZKI", year: "2023", img: "https://live.staticflickr.com/65535/53097973901_bad77dc6af_k.jpg", link: "https://www.flickr.com/photos/198890299@N03/albums/72177720310298912" }
];
---

<section id="media" class="relative bg-[#0b100b] text-white py-12 md:py-24 font-sans border-t border-white/10 selection:bg-neon-green selection:text-black overflow-hidden">
    
    <!-- Custom Gallery Background Pattern (Diagonal Stripes) -->
    <div class="absolute inset-0 z-0 pointer-events-none" style="background-image: repeating-linear-gradient(-45deg, rgba(255,255,255,0.03) 0, rgba(255,255,255,0.03) 1px, transparent 1px, transparent 16px);"></div>
    
    <div class="relative z-10 w-full">
        <!-- Header -->
        <div class="max-w-7xl mx-auto px-4 md:px-8 relative mb-12 md:mb-16">
            <!-- Background Text Decoration -->
            <div
                class="absolute -top-4 md:-top-10 left-1/2 -translate-x-1/2 w-screen overflow-hidden opacity-10 pointer-events-none select-none flex justify-center"
            >
                <span
                    class="text-6xl sm:text-8xl md:text-[200px] font-black italic leading-none text-transparent stroke-text-white whitespace-nowrap"
                >
                    MULTIMEDIA
                </span>
            </div>

            <div
                class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/20 pb-8"
            >
                <div
                    class="flex flex-col items-center md:items-start text-center md:text-left w-full md:w-auto"
                >
                    <div class="flex items-center gap-4 mb-2">
                        <div class="h-[1px] w-12 bg-neon-green"></div>
                        <span
                            class="text-neon-green font-mono text-xs md:text-sm tracking-[0.3em] uppercase"
                            >03 // Multimedia</span
                        >
                    </div>
                    <h2
                        class="text-4xl md:text-8xl font-sans font-black italic uppercase leading-[0.85] tracking-tighter"
                    >
                        <span
                            class="block text-transparent stroke-text-white opacity-70"
                            >Ikus-entzunezko</span
                        >
                        <span
                            class="text-neon-green drop-shadow-[0_0_15px_rgba(0,255,65,0.4)]"
                            >Galeria</span
                        >
                    </h2>
                </div>

                <div class="max-w-md text-center md:text-right">
                    <p
                        class="font-mono text-[10px] md:text-xs leading-relaxed text-white/70 uppercase tracking-wide mb-4"
                    >
                        <span class="text-neon-green">///</span> Sentitu lasterketaren indarra. Edizio guztietako momentu onenak. Irudiak eta bideoak.
                    </p>
                </div>
            </div>
        </div>
        <!-- 1. BROADCASTS SECTION -->
        <div class="max-w-7xl mx-auto px-4 md:px-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4 border-b border-white/10 pb-6 md:pb-8">
                <div class="flex items-center gap-4">
                    <h2 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-white">RETRANSMISIOAK</h2>
                    <div class="w-px h-6 bg-white/20 hidden md:block"></div>
                    <span class="text-neon-green font-mono text-xs tracking-widest uppercase hidden md:block">Edizio guztiak</span>
                </div>
            </div>

            <!-- Broadcast Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                {broadcasts.map(b => (
                    <a href={b.link} target="_blank" rel="noopener noreferrer" class="group cursor-pointer block">
                        <div class="relative aspect-video bg-white/5 overflow-hidden mb-4 border border-white/10 md:group-hover:border-neon-green/50 transition-all duration-300">
                            <img src={b.img} loading="lazy" class="w-full h-full object-cover opacity-80 md:group-hover:opacity-100 transition-opacity duration-500 md:group-hover:scale-105" alt={b.title} />
                            
                            <!-- Year Badge -->
                            <div class={`absolute top-3 left-3 px-2 py-1 text-[10px] sm:text-xs font-mono font-bold ${b.active ? 'bg-neon-green text-black' : 'bg-white/20 text-white backdrop-blur-md'}`}>
                                {b.year}
                            </div>

                            <!-- Duration Badge -->
                            <div class="absolute bottom-3 right-3 bg-black/80 px-2 py-1 text-[10px] sm:text-xs font-mono text-neon-green">
                                {b.duration}
                            </div>

                            <!-- Play icon -->
                            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                                <div class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-black/50 border border-white/20 flex items-center justify-center backdrop-blur-sm md:group-hover:bg-neon-green md:group-hover:border-neon-green transition-all transform md:group-hover:scale-110">
                                    <svg viewBox="0 0 24 24" fill="currentColor" class={`w-5 h-5 md:w-6 md:h-6 ml-1 transition-colors ${b.active ? 'text-white md:group-hover:text-black' : 'text-white md:group-hover:text-black'}`}><path d="M8 5v14l11-7z" /></svg>
                                </div>
                            </div>
                        </div>
                        <h3 class="text-base sm:text-lg md:text-xl font-bold text-white md:group-hover:text-neon-green active:text-neon-green transition-colors">{b.title}</h3>
                        <p class="text-[8px] sm:text-[10px] font-mono text-white/40 uppercase tracking-widest mt-1 md:mt-2">{b.subtitle}</p>
                    </a>
                ))}
            </div>
        </div>
        </div>
    </div>

    <!-- 2. HIGHLIGHTS SECTION -->
    <div class="mt-16 md:mt-24 relative w-full overflow-hidden border-y border-white/10 bg-[#050805]">
        <div class="absolute z-20 left-0 top-0 bg-neon-green px-4 md:px-6 py-1 md:py-2">
            <span class="text-black font-mono font-bold tracking-widest text-[10px] md:text-xs">Argazki Sorta</span>
        </div>
        
        <!-- Auto-Scrolling Carousel -->
        <div class="flex w-max animate-carousel md:hover:[animation-play-state:paused] items-stretch">
            {[...highlights, ...highlights, ...highlights].map(h => {
                const isVertical = h.includes('54613520916') || h.includes('53902038638');
                return (
                    <div class="flex-none w-[70vw] sm:w-[45vw] md:w-[25vw] aspect-[4/3] md:aspect-[5/4] shrink-0 border-r border-white/10 relative group overflow-hidden bg-black">
                        {isVertical && (
                            <div class="absolute inset-0 bg-black/80 z-0"></div>
                        )}
                        <img 
                            src={h} 
                            loading="lazy"
                            class={`absolute inset-0 w-full h-full grayscale opacity-60 md:group-hover:grayscale-0 md:group-hover:opacity-100 active:grayscale-0 active:opacity-100 transition-all duration-500 md:group-hover:scale-105 ${isVertical ? 'object-contain p-4' : 'object-cover'}`} 
                            alt="Highlight" 
                        />
                    </div>
                );
            })}
        </div>
    </div>

    <!-- 3. ALBUMS SECTION -->
    <div class="max-w-7xl mx-auto px-4 md:px-8 mt-16 md:mt-24 mb-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-10 gap-6 border-b border-white/10 pb-6 md:pb-8">
            <div class="flex items-center gap-4">
                <h2 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-white">ALBUMAK</h2>
                <div class="w-px h-6 bg-white/20 hidden md:block"></div>
                <span class="text-neon-green font-mono text-xs tracking-widest uppercase hidden md:block">FLICKR GALLERIES</span>
            </div>
        </div>

        <!-- Album grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-8">
            {albums.map((a, i) => (
                <a href={a.link} target="_blank" rel="noopener noreferrer" class="group cursor-pointer relative aspect-square sm:aspect-[4/3] overflow-hidden bg-white/5 border border-white/10 md:hover:border-neon-green/50 active:border-neon-green/50 transition-colors block">
                    <img src={a.img} loading="lazy" class="w-full h-full object-cover opacity-60 md:group-hover:opacity-100 active:opacity-100 transition-opacity duration-500 md:group-hover:scale-110" alt={a.title} />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent"></div>
                    
                    <!-- Year Badge -->
                    <div class="absolute top-2 right-2 md:top-4 md:right-4 bg-black/60 backdrop-blur-md px-2 py-1 text-[10px] md:text-xs font-mono text-white/80 border border-white/10 md:group-hover:border-neon-green/30 transition-colors font-bold">
                        {a.year}
                    </div>

                    <div class="absolute bottom-4 md:bottom-6 left-4 md:left-6 right-4 md:right-6 flex justify-between items-end">
                        <div>
                            <h4 class="text-lg md:text-2xl font-bold text-white md:group-hover:text-neon-green active:text-neon-green transition-colors truncate">{a.title}</h4>
                            <p class="text-[9px] md:text-[10px] font-mono text-white/50 tracking-widest mt-1 uppercase">{a.photos}</p>
                        </div>
                        <div class="w-8 h-8 md:w-10 md:h-10 rounded-full border border-white/20 flex items-center justify-center md:group-hover:bg-neon-green md:group-hover:text-black md:group-hover:border-neon-green transition-all transform md:group-hover:scale-110">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 md:w-5 md:h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                            </svg>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .stroke-text-white {
        -webkit-text-stroke: 2px rgb(255, 255, 255);
    }
    
    @keyframes carousel {
        0% { transform: translateX(0); }
        100% { transform: translateX(-33.333333%); }
    }
    
    .animate-carousel {
        animation: carousel 35s linear infinite;
        will-change: transform;
    }
</style>
