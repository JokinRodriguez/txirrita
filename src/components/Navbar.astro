---
// Assuming logo is in public or assets. Using text if logo fails, but user said "Utiliza el logo que te proporciono".
// Typically public assets are referenced by URL.
---

<nav
    class="fixed top-0 left-0 w-full z-[150] px-6 md:px-12 h-20 md:h-24 flex justify-between items-center border-b border-white/10 transition-all duration-300 box-border"
    :class="mobileMenuOpen ? 'bg-[#050805] backdrop-blur-none' : 'bg-stone-950/80 backdrop-blur-md'"
    x-data="{ mobileMenuOpen: false }"
    x-init="$watch('mobileMenuOpen', value => document.body.classList.toggle('overflow-hidden', value))"
    @keydown.escape="mobileMenuOpen = false"
>
    <!-- Logo Layer -->
    <div class="flex items-center gap-4 z-[160]">
        <a
            href="/"
            class="block w-28 md:w-32 active:opacity-80 md:hover:opacity-80 transition-opacity"
        >
            <img
                src="/logo-white.png?v=3"
                alt="Txirrita Mendi Lasterketa"
                class="w-full h-auto"
            />
        </a>
    </div>

    <!-- Desktop Menu -->
    <div
        class="hidden md:flex gap-8 text-[10px] md:text-xs font-mono tracking-widest uppercase items-center z-[160]"
    >
        {
            [
                { name: "Ibilbidea", href: "/#course" },
                { name: "Arauak", href: "/#rules" },
                { name: "Multimedia", href: "/#media" },
                { name: "Babesleak", href: "/#partners" },
                { name: "Boluntarioak", href: "/#boluntarioak" },
            ].map((item) => (
                <a
                    href={item.href}
                    class="md:hover:text-neon-green active:text-neon-green transition-colors relative group text-white flex items-center"
                >
                    <span class="opacity-0 md:group-hover:opacity-100 transition-all duration-300 text-neon-green -ml-2 md:group-hover:translate-x-0 translate-x-2 font-black">
                        [
                    </span>
                    <span class="mx-1 opacity-70 md:group-hover:opacity-100 transition-opacity">
                        {item.name}
                    </span>
                    <span class="opacity-0 md:group-hover:opacity-100 transition-all duration-300 text-neon-green -mr-2 md:group-hover:-translate-x-0 -translate-x-2 font-black">
                        ]
                    </span>
                </a>
            ))
        }
        <a
							href="https://inscripciones.kronoak.com/es/evento/txirrita-mendi-lasterketa-2026?auto=1&frm=0&tit=1&men=1&stop=0&pat=1&cmp=1&"
							target="_blank"
							class="text-xs uppercase tracking-widest font-mono text-neon-green border border-neon-green/30 px-6 py-2.5 hover:bg-neon-green hover:text-black transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-[0_0_15px_rgba(0,255,65,0.2)] hover:shadow-[0_0_25px_rgba(0,255,65,0.4)]"
						>
							Izena eman
						</a>
    </div>

    <!-- Mobile Toggle Button -->
    <button
        class="md:hidden z-[160] flex items-center gap-3 px-4 py-2 bg-white/5 border border-white/10 rounded-full active:bg-white/10 transition-all duration-300"
        @click="mobileMenuOpen = !mobileMenuOpen"
        aria-label="Menua"
    >
        <span
            class="text-[10px] font-mono uppercase tracking-[0.2em] text-white/70 transition-colors"
            x-text="mobileMenuOpen ? 'itxi' : 'menua'"></span>
        <div class="flex flex-col gap-1.5 justify-center items-end w-5">
            <div
                class="h-[2px] bg-white transition-all duration-300 origin-center"
                :class="mobileMenuOpen ? 'w-5 translate-y-[4px] rotate-45' : 'w-5'"
            >
            </div>
            <div
                class="h-[2px] bg-neon-green transition-all duration-300 origin-center"
                :class="mobileMenuOpen ? 'w-5 -translate-y-[4px] -rotate-45' : 'w-3'"
            >
            </div>
        </div>
    </button>

    <!-- Full-Screen Mobile Menu -->
    <div
        class="fixed inset-0 bg-[#050805] z-[140] flex flex-col p-10 pt-32 transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none md:hidden"
        :class="mobileMenuOpen ? '!opacity-100 !pointer-events-auto' : ''"
    >
        <!-- Links Container -->
        <div class="flex flex-col gap-2 relative z-10">
            {
                [
                    { name: "Ibilbidea", href: "/#course", id: "01" },
                    { name: "Arauak", href: "/#rules", id: "02" },
                    { name: "Multimedia", href: "/#media", id: "03" },
                    { name: "Babesleak", href: "/#partners", id: "04" },
                    { name: "Boluntarioak", href: "/#boluntarioak", id: "05" },
                ].map((item, index) => (
                    <div class="border-b border-white/5 py-4">
                        <a
                            href={item.href}
                            class="group flex items-center justify-between no-underline"
                            @click="mobileMenuOpen = false"
                        >
                            <div class="flex items-baseline gap-4">
                                <span class="text-neon-green font-mono text-[10px] tracking-tighter opacity-70">
                                    {item.id} //
                                </span>
                                <span class="text-4xl font-black italic uppercase tracking-tighter text-white active:text-neon-green transition-colors duration-300">
                                    {item.name}
                                </span>
                            </div>
                            <div class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center active:border-neon-green/50 transition-colors">
                                <svg
                                    class="w-4 h-4 text-white active:text-neon-green transition-colors"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2.5"
                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                    />
                                </svg>
                            </div>
                        </a>
                    </div>
                ))
            }

            <div class="mt-12">
                <a
                    href="https://inscripciones.kronoak.com/es/evento/txirrita-mendi-lasterketa-2026?auto=1&frm=0&tit=1&men=1&stop=0&pat=1&cmp=1&"
                    target="_blank"
                    class="block w-full py-6 bg-neon-green text-black font-black italic uppercase text-2xl text-center active:bg-white transition-all duration-300 transform -skew-x-12 relative"
                    @click="mobileMenuOpen = false"
                >
                    <span class="block skew-x-12 relative z-10">Izena Eman</span
                    >
                    <div class="hidden"></div>
                </a>
            </div>
        </div>

        <!-- Footer Info -->
        <div class="mt-auto flex flex-col gap-6 relative z-10">
            <div class="flex gap-8">
                <a
                    href="https://instagram.com"
                    class="text-xs font-mono uppercase tracking-widest text-white/50 active:text-neon-green transition-colors"
                    >Instagram</a
                >
                <a
                    href="mailto:info@txirrita.com"
                    class="text-xs font-mono uppercase tracking-widest text-white/50 active:text-neon-green transition-colors"
                    >Email</a
                >
            </div>
            <div
                class="text-[8px] font-mono text-white/20 tracking-[0.3em] uppercase"
            >
                ALTZA // DONOSTIA<br />
                © 2025 TXIRRITA MENDI LASTERKETA
            </div>
        </div>
    </div>
</nav>

<style>
    :global(body.overflow-hidden) {
        overflow: hidden !important;
    }
</style>
