---

---

<section
    id="boluntarioak"
    class="relative bg-[#0a0f0a] text-white font-sans overflow-hidden border-t border-white/10"
>
    <!-- Background subtle glow -->
    <div
        class="absolute top-0 right-0 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-neon-green/10 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/2 will-change-[filter]"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-neon-green/5 rounded-full blur-3xl pointer-events-none translate-y-1/3 -translate-x-1/3 will-change-[filter]"
    >
    </div>

    <div
        class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 pt-12 md:pt-16 pb-4"
    >
        <!-- Header -->
        <div class="relative mb-8 md:mb-10">
            <!-- Background Text Decoration -->
            <div
                class="absolute -top-4 md:-top-10 left-1/2 -translate-x-1/2 w-full overflow-hidden opacity-10 pointer-events-none select-none flex justify-center"
            >
                <span
                    class="text-[10vw] sm:text-8xl md:text-[200px] font-black italic leading-none text-transparent stroke-text-white whitespace-nowrap overflow-hidden"
                >
                    BOLUNTARIOAK
                </span>
            </div>

            <div
                class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/20 pb-8"
            >
                <div
                    class="flex flex-col items-center md:items-start text-center md:text-left w-full md:w-auto"
                >
                    <div class="flex items-center gap-4 mb-2">
                        <div class="h-[1px] w-12 bg-neon-green"></div>
                        <span
                            class="text-neon-green font-mono text-xs md:text-sm tracking-[0.3em] uppercase"
                            >05 // Boluntarioak</span
                        >
                    </div>
                    <h2
                        class="text-[9vw] sm:text-4xl md:text-8xl font-sans font-black italic uppercase leading-[0.85] tracking-tighter break-words"
                    >
                        <span
                            class="block text-transparent stroke-text-white opacity-70"
                            >Egin zaitez</span
                        >
                        <span
                            class="text-neon-green drop-shadow-[0_0_15px_rgba(0,255,65,0.4)]"
                            >Laguntzaile</span
                        >
                    </h2>
                </div>

                <div class="max-w-md text-center md:text-right">
                    <p
                        class="font-mono text-[10px] md:text-xs leading-relaxed text-white/70 uppercase tracking-wide mb-4"
                    >
                        <span class="text-neon-green">///</span> Bizi Altzako Mendi
                        Lasterketa barrutik! Lagundu gaitzazu dena martxan jartzen
                        eta izan zaitez gure taldeko parte.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Section (Centered Column) -->
    <div class="flex flex-col items-center w-full relative z-10">
        <!-- Top Block: Image + Izan Parte -->
        <div
            class="w-full relative bg-black border-b border-white/5 overflow-hidden flex items-center justify-center min-h-[40vh] sm:min-h-[60vh] xl:min-h-[500px] p-4 sm:p-12"
        >
            <!-- Background Image with Parallax effect -->
            <img
                src="/highlights/54613710349_55ce56087d_c.jpg"
                alt="Volunteers Background"
                class="absolute inset-0 w-full h-full object-cover opacity-70 grayscale-[0.3] hover:grayscale-0 transition-transform duration-[2000ms] md:hover:scale-105 will-change-transform"
            />
            <div
                class="absolute inset-0 bg-gradient-to-t xl:bg-gradient-to-r from-black/80 via-black/30 to-black/10"
            >
            </div>

            <!-- Neon Box (Shrunk) -->
            <div
                class="relative z-10 border border-neon-green/30 p-4 sm:p-10 w-full max-w-[60vw] sm:max-w-md flex flex-col items-center justify-center bg-black/40 backdrop-blur-md shadow-[0_0_40px_rgba(0,255,65,0.15)] md:hover:border-neon-green/60 overflow-hidden"
            >
                <h2
                    class="text-[10vw] sm:text-6xl md:text-8xl font-sans font-black italic uppercase leading-[0.8] tracking-tighter text-transparent stroke-text-white opacity-90 mb-1"
                >
                    PARTE
                </h2>
                <h2
                    class="text-[12vw] sm:text-7xl md:text-[110px] font-sans font-black italic uppercase leading-[0.8] tracking-tighter text-neon-green drop-shadow-[0_0_25px_rgba(0,255,65,0.4)] mb-4 md:mb-6"
                >
                    HARTU
                </h2>
                <div
                    class="h-px w-full bg-gradient-to-r from-transparent via-neon-green/60 to-transparent mb-5"
                >
                </div>
                <p
                    class="font-mono text-[12px] sm:text-xs text-white font-bold tracking-[0.4em] uppercase text-center w-full"
                >
                    Egin zaitez laguntzaile
                </p>
            </div>
        </div>

        <!-- Bottom Block: Content & CTA -->
        <div
            class="w-full max-w-4xl bg-[#0d120d]/50 p-6 sm:p-12 xl:p-20 flex flex-col items-center text-center justify-center relative border-b border-white/5 overflow-hidden"
        >
            <!-- Grid pattern background -->
            <div
                class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(rgba(255,255,255,1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,1)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none"
            >
            </div>

            <div class="relative z-10 mt-8 xl:mt-0">
                <h3
                    class="text-[10vw] sm:text-7xl xl:text-[90px] font-black italic uppercase leading-[0.85] tracking-tighter mb-4 text-white drop-shadow-xl select-none break-words overflow-hidden"
                >
                    JENDE BILA<br />GABILTZA!
                </h3>
                <p
                    class="text-balance text-lg sm:text-2xl md:text-3xl font-black text-white/50 mb-10 sm:mb-16 uppercase tracking-tight italic"
                >
                    Zatoz Altzako mendi lasterketa barrutik bizitzera!
                </p>

                <div
                    class="mb-8 sm:mb-12 bg-white/[0.03] border border-white/10 p-4 sm:p-8 backdrop-blur-sm rounded-lg hover:bg-white/[0.05] transition-colors duration-300 w-full max-w-2xl mx-auto overflow-hidden"
                >
                    <p
                        class="font-mono text-[9px] sm:text-[10px] md:text-xs text-neon-green tracking-widest uppercase mb-2 sm:mb-3 flex items-center justify-center gap-2 font-semibold"
                    >
                        ZUZENEKO KONTAKTUA
                    </p>
                    <a
                        href="mailto:txirritamendilasterketa@gmail.com"
                        class="text-[4vw] xs:text-lg sm:text-xl md:text-3xl text-white font-black break-all md:hover:text-neon-green active:text-neon-green transition-colors duration-300 inline-block border-b border-transparent hover:border-neon-green/50 pb-1"
                    >
                        txirritamendilasterketa<wbr />@gmail.com
                    </a>
                </div>

                <a
                    href="mailto:txirritamendilasterketa@gmail.com"
                    class="group relative w-full sm:w-auto mx-auto inline-flex bg-neon-green text-black px-4 sm:px-12 py-4 sm:py-7 font-black text-base sm:text-xl md:text-2xl uppercase tracking-[0.1em] sm:tracking-[0.2em] active:bg-white md:hover:bg-transparent md:hover:text-neon-green border-2 border-neon-green transition-all duration-500 items-center justify-center shadow-[0_0_20px_rgba(0,255,65,0.2)] md:hover:shadow-[0_0_30px_rgba(0,255,65,0.4)] overflow-hidden"
                >
                    <div
                        class="absolute inset-0 w-full h-full bg-black translate-y-[100%] group-hover:translate-y-0 transition-transform duration-300 ease-in-out"
                    >
                    </div>
                    <span
                        class="relative z-10 flex items-center gap-2 sm:gap-4"
                    >
                        EMAN IZENA HEMEN
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-6 h-6 sm:w-8 sm:h-8 md:group-hover:translate-x-2 transition-transform duration-300"
                        >
                            <path
                                d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z"
                            ></path>
                            <path
                                d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z"
                            ></path>
                        </svg>
                    </span>
                </a>

                <p
                    class="font-mono text-[9px] sm:text-[12px] text-white/70 tracking-[0.15em] mt-8 sm:mt-10 uppercase max-w-md mx-auto leading-relaxed"
                >
                    Idatzi iezaguzu eta lehenbailehen emango dizugu informazio
                    guztia. <br class="hidden sm:block" />Izan zaitez dena
                    posible egiten duen taldeko kide!
                </p>
            </div>
        </div>
    </div>

    <!-- Bottom Benefits Section -->
    <div class="max-w-7xl mx-auto px-4 md:px-8 pt-12 pb-24 relative z-10">
        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-8"
        >
            <div class="max-w-3xl">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-[1px] w-12 bg-neon-green"></div>
                    <span
                        class="text-neon-green font-mono text-xs sm:text-sm tracking-[0.3em] font-bold uppercase"
                    >
                        ABANTAILAK
                    </span>
                </div>
            </div>
        </div>

        <!-- Cards Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8"
        >
            <!-- Benefit 1 -->
            <div
                class="bg-white/[0.02] border border-white/5 p-5 sm:p-10 relative flex flex-col group active:bg-white/[0.04] md:hover:bg-white/[0.04] active:border-neon-green/40 md:hover:border-neon-green/40 transition-all duration-500 overflow-hidden rounded-xl md:hover:-translate-y-2 md:hover:shadow-[0_20px_40px_-15px_rgba(0,255,65,0.1)]"
            >
                <!-- Massive number behind -->
                <span
                    class="absolute -top-4 sm:-top-8 -right-4 sm:-right-6 text-[120px] sm:text-[180px] font-black italic text-white/[0.02] select-none group-hover:text-neon-green/[0.03] transition-colors duration-500 font-germania pointer-events-none"
                    >01</span
                >

                <div class="relative z-10 flex flex-col h-full">
                    <div
                        class="w-16 h-16 rounded-2xl bg-black/60 border border-white/10 flex items-center justify-center mb-8 sm:mb-12 group-hover:border-neon-green/60 transition-colors duration-500 shadow-xl"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            class="w-10 h-10 text-white/80 group-hover:text-neon-green group-hover:scale-110 group-hover:drop-shadow-[0_0_10px_rgba(0,255,65,0.5)] transition-all duration-500"
                        >
                            <!-- Smoke -->
                            <path
                                d="M10 2c0 .5-.5 1-1 1s-1 .5-1 1"
                                stroke-linecap="round"></path>
                            <path
                                d="M14 2c0 .5-.5 1-1 1s-1 .5-1 1"
                                stroke-linecap="round"></path>
                            <!-- Bowl/Plate -->
                            <path
                                d="M3 12c0 4 4 7 9 7s9-3 9-7"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                            <path
                                d="M3 12h18"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                            <path
                                d="M7 19v2h10v-2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                    </div>
                    <h4
                        class="text-2xl sm:text-3xl font-black uppercase tracking-tight mb-4 text-white group-hover:text-neon-green transition-colors duration-300 drop-shadow-md"
                    >
                        PINTXOAK ETA EDARIAK
                    </h4>
                    <p
                        class="text-base sm:text-lg text-white/60 font-medium leading-relaxed mb-6 mt-auto"
                    >
                        Lasterketa egunean pintxoak eta edariak ziurtatuta
                        edukiko dituzu indarrak berritzeko.
                    </p>
                </div>
                <!-- Animated bottom border line -->
                <div
                    class="absolute bottom-0 left-0 w-full h-[3px] bg-gradient-to-r from-neon-green to-transparent scale-x-0 origin-left md:group-hover:scale-x-100 transition-transform duration-700 ease-out"
                >
                </div>
            </div>

            <!-- Benefit 2 -->
            <div
                class="bg-white/[0.02] border border-white/5 p-5 sm:p-10 relative flex flex-col group active:bg-white/[0.04] md:hover:bg-white/[0.04] active:border-neon-green/40 md:hover:border-neon-green/40 transition-all duration-500 overflow-hidden rounded-xl md:hover:-translate-y-2 md:hover:shadow-[0_20px_40px_-15px_rgba(0,255,65,0.1)]"
            >
                <span
                    class="absolute -top-4 sm:-top-8 -right-4 sm:-right-6 text-[120px] sm:text-[180px] font-black italic text-white/[0.02] select-none group-hover:text-neon-green/[0.03] transition-colors duration-500 font-germania pointer-events-none"
                    >02</span
                >

                <div class="relative z-10 flex flex-col h-full">
                    <div
                        class="w-16 h-16 rounded-2xl bg-black/60 border border-white/10 flex items-center justify-center mb-8 sm:mb-12 group-hover:border-neon-green/60 transition-colors duration-500 shadow-xl"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="w-8 h-8 text-white/80 group-hover:text-neon-green group-hover:scale-110 group-hover:drop-shadow-[0_0_10px_rgba(0,255,65,0.5)] transition-all duration-500"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H4.5a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"
                            ></path>
                        </svg>
                    </div>
                    <h4
                        class="text-2xl sm:text-3xl font-black uppercase tracking-tight mb-4 text-white group-hover:text-neon-green transition-colors duration-300 drop-shadow-md"
                    >
                        OPARI POLTSA
                    </h4>
                    <p
                        class="text-base sm:text-lg text-white/60 font-medium leading-relaxed mb-6 mt-auto"
                    >
                        Boluntarioen lantaldearentzako opari poltsa berezia,
                        lasterketako detaile eta oroigarriekin.
                    </p>
                </div>

                <div
                    class="absolute bottom-0 left-0 w-full h-[3px] bg-gradient-to-r from-neon-green to-transparent scale-x-0 origin-left md:group-hover:scale-x-100 transition-transform duration-700 ease-out"
                >
                </div>
            </div>

            <!-- Benefit 3 -->
            <div
                class="bg-white/[0.02] border border-white/5 p-5 sm:p-10 relative flex flex-col group active:bg-white/[0.04] md:hover:bg-white/[0.04] active:border-neon-green/40 md:hover:border-neon-green/40 transition-all duration-500 overflow-hidden rounded-xl lg:col-span-1 md:col-span-2 lg:col-start-3 md:hover:-translate-y-2 md:hover:shadow-[0_20px_40px_-15px_rgba(0,255,65,0.1)]"
            >
                <span
                    class="absolute -top-4 sm:-top-8 -right-4 sm:-right-6 text-[120px] sm:text-[180px] font-black italic text-white/[0.02] select-none group-hover:text-neon-green/[0.03] transition-colors duration-500 font-germania pointer-events-none"
                    >03</span
                >

                <div
                    class="w-16 h-16 shrink-0 rounded-2xl bg-black/60 border border-white/10 flex items-center justify-center mb-8 sm:mb-12 group-hover:border-neon-green/60 transition-colors duration-500 shadow-xl"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        class="w-8 h-8 text-white/80 group-hover:text-neon-green group-hover:scale-110 group-hover:drop-shadow-[0_0_10px_rgba(0,255,65,0.5)] transition-all duration-500"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"
                        ></path>
                    </svg>
                </div>
                <h4
                    class="text-2xl sm:text-3xl font-black uppercase tracking-tight mb-4 text-white group-hover:text-neon-green transition-colors duration-300 drop-shadow-md"
                >
                    GIRO PAREGABEA
                </h4>
                <p
                    class="text-base sm:text-lg text-white/60 font-medium leading-relaxed mb-6 mt-auto"
                >
                    Giro eta lan-talde paregabea, mendi lasterketa barrutik bizi
                    eta esperientzia ahaztezin bat izateko.
                </p>

                <div
                    class="absolute bottom-0 left-0 w-full h-[3px] bg-gradient-to-r from-neon-green to-transparent scale-x-0 origin-left md:group-hover:scale-x-100 transition-transform duration-700 ease-out"
                >
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .stroke-text-white {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
    }
    @media (min-width: 768px) {
        .stroke-text-white {
            -webkit-text-stroke: 2px rgba(255, 255, 255, 0.4);
        }
    }

    /* Parallax script simulation via CSS */
    @supports (animation-timeline: scroll()) {
        .parallax-bg {
            animation: parallax-scroll linear both;
            animation-timeline: scroll();
            animation-range: entry 0% exit 100%;
        }
    }

    @keyframes parallax-scroll {
        from {
            transform: translateY(0);
        }
        to {
            transform: translateY(15%);
        }
    }
</style>
