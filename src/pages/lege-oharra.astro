---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
    <Navbar />
    <main class="pt-32 pb-24 bg-[#050805] text-white">
        <div class="max-w-4xl mx-auto px-6 md:px-8">
            <h1
                class="font-germania text-4xl md:text-5xl mb-12 text-neon-green tracking-tight"
            >
                Lege Oharra
            </h1>

            <div
                class="prose prose-invert prose-neon max-w-none space-y-10 text-white/70 leading-relaxed font-sans text-justify"
            >
                <section>
                    <p class="text-lg text-white/90">
                        Lege-ohar honek (aurrerantzean, “Lege Oharra”)
                        www.txirritamendilasterketa.eus Interneteko atariaren
                        (aurrerantzean, “Webgunea”) erabilera arautzen du,
                        ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”rena, helbide soziala honako hau duena: LAU
                        HAIZETA kalea Behea, DONOSTIA, 20017, GIPUZKOA (IFZ:
                        CD0001035).
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Legeria
                    </h2>
                    <p>
                        Oro har, ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”ren eta webgunean dauden zerbitzu
                        telematikoen arteko harremanak Espainiako legeriaren eta
                        jurisdikzioaren mende daude.
                    </p>
                    <p>
                        Alderdiek berariaz uko egiten diote legokiekeen foruari,
                        eta berariaz jartzen dituzte DONOSTIAko epaitegi eta
                        auzitegien esku, kontratu-baldintza hauek
                        interpretatzean edo betearaztean sor daitekeen edozein
                        eztabaida ebazteko.
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Edukia eta erabilera
                    </h2>
                    <p>
                        Erabiltzaileari jakinarazten zaio, eta onartzen du,
                        webgune honetara sartzeak ez duela esan nahi, inola ere,
                        ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”rekin merkataritza-harremana hasi denik.
                    </p>
                    <p>
                        Webgunearen titularra ez da identifikatzen bere
                        laguntzaileek bertan emandako iritziekin. Elkarteak
                        beretzat gordetzen du bere webgunean egokitzat jotzen
                        dituen aldaketak aldez aurretik jakinarazi gabe egiteko
                        eskubidea, eta haren bidez ematen diren edukiak eta
                        zerbitzuak aldatu, ezabatu edo gehitu ahal izango ditu,
                        baita horiek bere zerbitzarietan aurkezteko edo
                        kokatzeko modua ere.
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Jabetza intelektuala eta industriala
                    </h2>
                    <p>
                        Webguneen edukiaren, diseinu grafikoaren eta kodeen
                        jabetza intelektualaren eskubideak ALTZATARRA KIROL
                        ELKARTEA “TXIRRITA MENDI LASTERKETA”ren
                        titulartasunekoak dira, eta, beraz, debekatuta dago
                        haien erreprodukzioa, banaketa, komunikazio publikoa,
                        eraldaketa edo haien webguneen edukiekin egin daitekeen
                        beste edozein jarduera egitea, baita iturriak aipatuta
                        ere, ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”k idatzizko baimena eman ezean. Enpresaren
                        webguneetan dauden izen komertzial, marka edo zeinu
                        guztiak jabeenak dira, eta legez babestuta daude.
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Estekak (Loturak)
                    </h2>
                    <p>
                        ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI LASTERKETA”ren
                        web orrietan estekak (loturak) agertzeak informazioa
                        ematea baino ez du helburu, eta ez du inola ere horiei
                        buruzko iradokizunik, gonbidapenik edo gomendiorik
                        ekarriko.
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Konfidentzialtasuna eta Datuen Babesa
                    </h2>
                    <p>
                        2016ko apirilaren 27ko DBEOn aurreikusitakoaren
                        ondorioetarako, ALTZATARRA KIROL ELKARTEA “TXIRRITA
                        MENDI LASTERKETA”k Erabiltzaileari jakinarazten dio
                        ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”rentzat eta bere erantzukizunpean sortutako
                        izaera pertsonaleko datuen tratamendu automatizatua
                        dagoela, Erabiltzailearekiko harremana mantentzeko eta
                        kudeatzeko, bai eta informazio-lanak egiteko ere.
                        Baldintza orokor hauek onartzen direnean, ALTZATARRA
                        KIROL ELKARTEA “TXIRRITA MENDI LASTERKETA”k bere
                        zerbitzuak emateko ezinbestekoak diren datu batzuk bildu
                        beharko dizkio erabiltzaileari.
                    </p>
                </section>

                <section>
                    <h2 class="font-germania text-2xl text-white mb-4">
                        Fitxategi eta formularioen erregistroa
                    </h2>
                    <p>
                        Erregistro-formularioa nahitaez bete behar da webgunean
                        eskaintzen diren zerbitzu jakin batzuetara sartzeko eta
                        haietaz gozatzeko. Eskatutako datu pertsonalak ez
                        emateak edo datuak babesteko politika hau ez onartzeak
                        datu pertsonalak eskatzen diren sustapenetan
                        harpidetzeko, erregistratzeko edo parte hartzeko
                        ezintasuna dakar.
                    </p>
                    <p>
                        2016ko apirilaren 27ko DBEOn aurreikusitakoaren
                        ondorioetarako, jakinarazten dizugu erabiltzaile gisa
                        erregistratzearen ondorioz lortzen diren datu
                        pertsonalak ALTZATARRA KIROL ELKARTEA “TXIRRITA MENDI
                        LASTERKETA”ren titulartasuneko fitxategi batean sartuko
                        direla (LAU HAIZETA kalea Behea, DONOSTIA, 20017,
                        GIPUZKOA (IFZ: CD0001035), eta ekainaren 11ko 1720/2007
                        Errege Dekretuan ezarritako segurtasun-neurriak
                        inplementatuta izango dituztela.
                    </p>
                </section>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
